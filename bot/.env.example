# ============================================
# Tashkent Cafe Bot — Environment Variables
# ============================================
# @BotFather dan olgan tokenni shu yerga yozing
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Telegram Web App URL (Mini App hosting manzili)
MINI_APP_URL=https://your-mini-app.vercel.app

# Admin Telegram ID (@userinfobot dan bilib oling)
ADMIN_CHAT_ID=123456789

# Server port
PORT=3001

# Google Cloud Vision API Key
# Google Cloud Console → API Keys → Vision API
GOOGLE_VISION_API_KEY=YOUR_GOOGLE_VISION_API_KEY

# To'lov qabul qiluvchi ism (chekda bo'lishi kerak)
PAYMENT_RECIPIENT=Tashkent

# To'lov bank raqami (KakaoBank yoki Toss)
BANK_ACCOUNT=3333-01-XXXXXXX
BANK_OWNER=Oshxona Egasi

# Bozor buyurtma eslatmasi vaqti (KST)
BOZOR_REMINDER_CRON=0 6 * * *
